{$DOMAIN}, :80 {
	root * /srv
	encode gzip

	handle /api/* {
		reverse_proxy challenges-backend:8080
	}

	# Strip the /solver prefix so the backend sees its real route (/solve).
	handle_path /solver/* {
		reverse_proxy solver-backend:8080
	}

	handle {
		try_files {path} /index.html
		file_server
	}
}
